# ---- copy to .env.local and fill in ----

# Google Sheet (must be shared "Anyone with the link can view")
SHEET_ID=1tGdJwefcQk0Slt_z6jTkt3bn5Y6NEeAYAZWin7uMfIE

# Session signing secret (any long random string). REQUIRED in production.
AUTH_SECRET=please-change-this-to-a-long-random-string

# Local testing without email: set to 1 so the OTP is returned to the UI/console.
# MUST be 0 (or unset) in production.
AUTH_DEV_MODE=1

# ---- Email (SMTP) — required to actually deliver OTP codes ----
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=apikey-or-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Carry Bee <no-reply@carrybee.com>

# ---- Persistence (Vercel KV / Upstash) — required for production ----
# Without these the app uses an in-memory store (fine for local dev only).
# KV_REST_API_URL=https://xxxx.upstash.io
# KV_REST_API_TOKEN=xxxxxxxx
